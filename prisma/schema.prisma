generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TENANT
  LANDLORD
  INSPECTOR
  ADMIN
}

enum VerificationTier {
  BASIC      // phone OTP only
  STANDARD   // CNIC uploaded
  VERIFIED   // NADRA confirmed
}

enum ListingStatus {
  DRAFT
  PENDING_PAYMENT
  ACTIVE
  PAUSED
  EXPIRED
  REMOVED
}

enum ListingType {
  EXCLUSIVE_RIGHT
  EXCLUSIVE_AGENCY
  OPEN
}

enum InspectionStatus {
  REQUESTED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LeaseStatus {
  DRAFT
  PENDING_SIGNATURES
  SIGNED
  ACTIVE
  EXPIRED
  TERMINATED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// 1. User
model User {
  id              String           @id @default(cuid())
  phone           String           @unique
  email           String?          @unique
  name            String?
  photoUrl        String?
  role            Role             @default(TENANT)
  verificationTier VerificationTier @default(BASIC)
  cnicFrontUrl    String?
  cnicBackUrl     String?
  cnicVerifiedAt  DateTime?
  isActive        Boolean          @default(true)
  acceptedTerms   Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  otps            OTP[]
  listings        Listing[]
  savedListings   SavedListing[]
  sentMessages    Message[]        @relation("SentMessages")
  conversations   ConversationParticipant[]
  tenantLeases    Lease[]          @relation("TenantLeases")
  landlordLeases  Lease[]          @relation("LandlordLeases")
  inspectionRequests InspectionRequest[] @relation("RequesterInspections")
  assignedInspections InspectionRequest[] @relation("InspectorInspections")
  payments        Payment[]
  viewingRequests ViewingRequest[]
  notifications   Notification[]
  savedSearches   SavedSearch[]
  maintenanceRequests MaintenanceRequest[]
  reviews         Review[]
}

// 2. OTP (for phone verification)
model OTP {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 3. Listing
model Listing {
  id            String        @id @default(cuid())
  landlordId    String
  title         String
  description   String?
  city          String
  locality      String
  address       String?
  latitude      Float?
  longitude     Float?
  propertyType  String        // House, Apartment, Studio, etc.
  rentAmount    Int           // in PKR
  rooms         Int
  bathrooms     Int
  areaSqft      Int?
  areaMarla     Float?
  furnishing    String        // Furnished, Semi-furnished, Unfurnished
  utilities     String[]      // ['Gas', 'Electricity', 'Water']
  listingType   ListingType   @default(OPEN)
  status        ListingStatus @default(DRAFT)
  isBoosted     Boolean       @default(false)
  boostExpiresAt DateTime?
  ownerVerified Boolean       @default(false)
  ownerDocUrl   String?
  expiresAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  landlord      User          @relation(fields: [landlordId], references: [id])
  photos        ListingPhoto[]
  saved         SavedListing[]
  conversations Conversation[]
  inspections   InspectionRequest[]
  leases        Lease[]
  payments      Payment[]
  viewingRequests ViewingRequest[]
  maintenanceRequests MaintenanceRequest[]
  reviews         Review[]
}

// 4. Listing photos
model ListingPhoto {
  id        String   @id @default(cuid())
  listingId String
  url       String
  isCover   Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// 5. Saved listings (bookmarks)
model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

// 6. Conversation + Messages
model Conversation {
  id          String   @id @default(cuid())
  listingId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing       Listing  @relation(fields: [listingId], references: [id])
  participants  ConversationParticipant[]
  messages      Message[]
  viewingRequests ViewingRequest[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  status         MessageStatus @default(SENT)
  createdAt      DateTime      @default(now())

  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User          @relation("SentMessages", fields: [senderId], references: [id])
}

// 7. Viewing request
model ViewingRequest {
  id             String   @id @default(cuid())
  conversationId String
  listingId      String
  requesterId    String
  proposedAt     DateTime
  status         String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, RESCHEDULED
  note           String?
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  listing        Listing      @relation(fields: [listingId], references: [id])
  requester      User         @relation(fields: [requesterId], references: [id])
}

// 8. Inspection request + report
model InspectionRequest {
  id           String           @id @default(cuid())
  listingId    String
  requesterId  String
  inspectorId  String?
  type         String           // MOVE_IN, MOVE_OUT, GENERAL
  status       InspectionStatus @default(REQUESTED)
  scheduledAt  DateTime?
  completedAt  DateTime?
  feeAmount    Int              @default(1800)
  reportPdfUrl String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  listing      Listing          @relation(fields: [listingId], references: [id])
  requester    User             @relation("RequesterInspections", fields: [requesterId], references: [id])
  inspector    User?            @relation("InspectorInspections", fields: [inspectorId], references: [id])
  checklistItems InspectionItem[]
}

model InspectionItem {
  id            String            @id @default(cuid())
  inspectionId  String
  category      String            // Electrical, Gas, Water, Structural
  status        String            // PASS, FAIL, FLAG
  notes         String?
  photoUrls     String[]

  inspection    InspectionRequest @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
}

// 9. Digital Lease
model Lease {
  id              String      @id @default(cuid())
  listingId       String
  tenantId        String
  landlordId      String
  status          LeaseStatus @default(DRAFT)
  startDate       DateTime?
  endDate         DateTime?
  monthlyRent     Int
  securityDeposit Int
  templateType    String      @default("STANDARD")
  pdfUrl          String?
  tenantSignedAt  DateTime?
  landlordSignedAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  listing         Listing     @relation(fields: [listingId], references: [id])
  tenant          User        @relation("TenantLeases", fields: [tenantId], references: [id])
  landlord        User        @relation("LandlordLeases", fields: [landlordId], references: [id])
}

// 10. Payment
model Payment {
  id          String        @id @default(cuid())
  userId      String
  listingId   String?
  type        String        // LISTING_FEE, BOOST, INSPECTION, VERIFICATION
  amount      Int           // PKR
  status      PaymentStatus @default(PENDING)
  gateway     String?       // JAZZCASH, EASYPAISA
  reference   String?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())

  user        User          @relation(fields: [userId], references: [id])
  listing     Listing?      @relation(fields: [listingId], references: [id])
}

// 11. Saved search
model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  city      String
  maxRent   Int?
  minRooms  Int?
  propType  String?
  label     String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 13. Maintenance request
model MaintenanceRequest {
  id          String   @id @default(cuid())
  listingId   String
  tenantId    String
  title       String
  description String
  category    String   // Plumbing, Electrical, Gas, Structural, Other
  priority    String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  status      String   @default("OPEN")   // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  photoUrls   String[]
  landlordNote String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing     Listing  @relation(fields: [listingId], references: [id])
  tenant      User     @relation(fields: [tenantId], references: [id])
}

// 14. Review
model Review {
  id        String   @id @default(cuid())
  listingId String
  authorId  String
  rating    Int      // 1–5
  comment   String?
  createdAt DateTime @default(now())

  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@unique([listingId, authorId])
}

// 12. Notification
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
